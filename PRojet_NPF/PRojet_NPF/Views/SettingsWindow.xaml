<Window x:Class="PRojet_NPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - Base de données" Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⚙ Paramètres de connexion"
                   Foreground="#e94560" FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,30"/>

        <TextBlock Grid.Row="1" Text="Chaîne de connexion :"
                   Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,5"/>

        <TextBox Grid.Row="2"
                 x:Name="ConnectionStringBox"
                 Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                 Background="#0f3460"
                 Foreground="White"
                 CaretBrush="White"
                 BorderBrush="#e94560"
                 BorderThickness="1"
                 Padding="10,8"
                 FontSize="13"
                 Margin="0,0,0,20"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Sauvegarder la connexion"
                    Command="{Binding SaveCommand}"
                    Height="35" Padding="15,0"
                    Background="#e94560" Foreground="White"
                    BorderThickness="0" Margin="0,0,10,0"/>

            <Button Content="Initialiser les données"
                    Command="{Binding InitDataCommand}"
                    Height="35" Padding="15,0"
                    Background="#0f3460" Foreground="White"
                    BorderBrush="#e94560" BorderThickness="1"/>
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Foreground="#2ecc71"
                   FontSize="13"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>