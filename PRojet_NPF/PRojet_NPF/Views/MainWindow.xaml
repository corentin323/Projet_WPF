<Window x:Class="PRojet_NPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hero Arena" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">
    <Grid>
        <Border Background="#16213e"
                CornerRadius="12"
                Padding="40"
                Width="320"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Hero Arena"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#e94560"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>
                <TextBlock Text="Nom d'utilisateur"
                           Foreground="#aaaaaa"
                           FontSize="12"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Background="#0f3460"
                         Foreground="White"
                         CaretBrush="White"
                         BorderBrush="#e94560"
                         BorderThickness="1"
                         Padding="10,8"
                         FontSize="14"
                         Margin="0,0,0,15"/>
                <TextBlock Text="Mot de passe"
                           Foreground="#aaaaaa"
                           FontSize="12"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox"
                             Background="#0f3460"
                             Foreground="White"
                             CaretBrush="White"
                             BorderBrush="#e94560"
                             BorderThickness="1"
                             Padding="10,8"
                             FontSize="14"
                             Margin="0,0,0,25"/>
                <Button Content="SE CONNECTER"
                        Height="40"
                        Background="#e94560"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=PasswordBox, Path=Password}"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#e94560"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>