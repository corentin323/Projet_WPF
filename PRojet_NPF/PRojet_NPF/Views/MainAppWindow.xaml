<Window x:Class="PRojet_NPF.Views.MainAppWindow"
        xmlns:local="clr-namespace:PRojet_NPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hero Arena" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Window.Resources>
        <local:PercentToWidthConverter x:Key="PercentToWidthConverter"/>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" 
                                Padding="12,6" Margin="2,0">
                            <ContentPresenter ContentSource="Header" 
                                            TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1a1a2e"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#0f3460"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Bouton Settings -->
        <Button Grid.Row="0"
                Content="⚙"
                Height="30"
                Background="Transparent"
                Foreground="#aaaaaa"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Right"
                Margin="0,5,10,0"
                Command="{Binding OpenSettingsCommand}"/>

        <TabControl Grid.Row="1"
                    Background="#16213e" 
                    BorderThickness="0"
                    Margin="10">

            <!-- Onglet Héros -->
            <TabItem Header="⚔ Héros">
                <Grid Background="#16213e">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="10">
                        <TextBlock Text="Héros disponibles"
                                   Foreground="#e94560"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <ListBox x:Name="HeroList"
                                 ItemsSource="{Binding Heroes}"
                                 SelectedItem="{Binding SelectedHero, Mode=TwoWay}"
                                 IsSynchronizedWithCurrentItem="True"
                                 Background="#0f3460"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Height="400"
                                 DisplayMemberPath="Name"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20">
                        <TextBlock Text="Détails du héros"
                                   Foreground="#e94560"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>
                        <TextBlock Foreground="White" FontSize="14" Margin="0,5">
                            <Run Text="Nom : " FontWeight="Bold"/>
                            <Run Text="{Binding SelectedHero.Name}"/>
                        </TextBlock>
                        <TextBlock Foreground="White" FontSize="14" Margin="0,5">
                            <Run Text="HP : " FontWeight="Bold"/>
                            <Run Text="{Binding SelectedHero.Health}"/>
                        </TextBlock>
                        <TextBlock Text="Spells :"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,15,0,5"/>
                        <ListBox ItemsSource="{Binding SelectedHero.Spells}"
                                 Background="#0f3460"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Height="200"
                                 DisplayMemberPath="Name"/>
                        <Button Content="Choisir ce héros"
                                Margin="0,20,0,0"
                                Height="35"
                                Width="150"
                                Background="#e94560"
                                Foreground="White"
                                BorderThickness="0"
                                HorizontalAlignment="Left"
                                Command="{Binding SelectHeroCommand}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Onglet Spells -->
            <TabItem Header="✨ Spells">
                <Grid Background="#16213e">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="10">
                        <TextBlock Text="Liste des spells"
                                   Foreground="#e94560"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <ComboBox ItemsSource="{Binding Heroes}"
                                  SelectedItem="{Binding FilterHero}"
                                  DisplayMemberPath="Name"
                                  Foreground="Black"
                                  Margin="0,0,0,10"/>
                        <ListBox ItemsSource="{Binding FilteredSpells}"
                                 SelectedItem="{Binding SelectedSpell}"
                                 Background="#0f3460"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Height="380"
                                 DisplayMemberPath="Name"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20">
                        <TextBlock Text="Détails du spell"
                                   Foreground="#e94560"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>
                        <TextBlock Foreground="White" FontSize="14" Margin="0,5">
                            <Run Text="Nom : " FontWeight="Bold"/>
                            <Run Text="{Binding SelectedSpell.Name}"/>
                        </TextBlock>
                        <TextBlock Foreground="White" FontSize="14" Margin="0,5">
                            <Run Text="Dégâts : " FontWeight="Bold"/>
                            <Run Text="{Binding SelectedSpell.Damage}"/>
                        </TextBlock>
                        <TextBlock Foreground="White" FontSize="14" Margin="0,5">
                            <Run Text="Description : " FontWeight="Bold"/>
                            <Run Text="{Binding SelectedSpell.Description}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Onglet Combat -->
            <TabItem Header="⚔ Combat" DataContext="{Binding CombatContext}">
                <Grid Background="#16213e" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Votre héros : "
                                   Foreground="White" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding PlayerHero.Name, FallbackValue='Aucun héros sélectionné'}"
                                   Foreground="#e94560" FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="Nouveau combat"
                                Command="{Binding NewCombatCommand}"
                                Margin="0,0,0,0" Padding="10,5"
                                Background="#e94560" Foreground="White"
                                BorderThickness="0"/>
                        <TextBlock Text="{Binding Score, StringFormat='Score : {0}'}"
                                   Foreground="#e94560" FontSize="16"
                                   FontWeight="Bold" Margin="20,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Foreground="White" FontWeight="Bold" FontSize="14"
                                       Text="{Binding PlayerHero.Name, FallbackValue='Joueur'}"/>
                            <TextBlock Foreground="#aaaaaa" FontSize="12"
                                       Text="{Binding PlayerHP, StringFormat='HP : {0}'}"/>
                            <Border Background="#333" Height="20" CornerRadius="10">
                                <Border Background="#2ecc71" CornerRadius="10"
                                        HorizontalAlignment="Left"
                                        Width="{Binding PlayerHPPercent, Converter={StaticResource PercentToWidthConverter}}"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="VS"
                                   Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Foreground="White" FontWeight="Bold" FontSize="14"
                                       Text="{Binding EnemyHero.Name, FallbackValue='Ennemi'}"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Foreground="#aaaaaa" FontSize="12"
                                       Text="{Binding EnemyHP, StringFormat='HP : {0}'}"
                                       HorizontalAlignment="Right"/>
                            <Border Background="#333" Height="20" CornerRadius="10">
                                <Border Background="#e94560" CornerRadius="10"
                                        HorizontalAlignment="Left"
                                        Width="{Binding EnemyHPPercent, Converter={StaticResource PercentToWidthConverter}}"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,0,0,15">
                        <TextBlock Text="Vos spells :" Foreground="White"
                                   FontWeight="Bold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding PlayerSpells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}"
                                            Margin="5" Padding="10,8"
                                            Background="#0f3460"
                                            Foreground="White"
                                            BorderBrush="#e94560"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.CombatContext.UseSpellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Grid.Row="3" Background="#0f3460" CornerRadius="8" Padding="15">
                        <TextBlock Text="{Binding CombatLog}"
                                   Foreground="White" FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>